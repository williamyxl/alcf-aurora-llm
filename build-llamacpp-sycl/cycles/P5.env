# P5: FLAT tensor split + VMM=0 + FA (bench-only) — was OOM under VMM=1
export ZE_FLAT_DEVICE_HIERARCHY=FLAT
export ZE_AFFINITY_MASK=0,1
export SPLIT_MODE=tensor
export NGL=99
export N_PREDICT=128
export GGML_SYCL_ENABLE_VMM=0
# RUN_CLI obsolete — MEASURE_TTFT=1 always in perf PBS
export MEASURE_TTFT=1
export RUN_BENCH=1
export EXTRA_ARGS='-fa on'
export BENCH_REPS=2
