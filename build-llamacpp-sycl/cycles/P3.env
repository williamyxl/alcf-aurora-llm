# P3: COMPOSITE whole GPU0 as 1 device + VMM=0 (same physical GPU, both tiles)
export ZE_FLAT_DEVICE_HIERARCHY=COMPOSITE
export ZE_AFFINITY_MASK=0
export SPLIT_MODE=none
export N_CTX=2048
export NGL=99
export N_PREDICT=128
export GGML_SYCL_ENABLE_VMM=0
# RUN_CLI obsolete — MEASURE_TTFT=1 always in perf PBS
export MEASURE_TTFT=1
export RUN_BENCH=1
export EXTRA_ARGS='-fa on'
