# F2: Phase F — 1 tile + first 16 MoE layers on CPU + local-DDR NUMA
export ZE_FLAT_DEVICE_HIERARCHY=FLAT
export ZE_AFFINITY_MASK=0
export SPLIT_MODE=none
export NGL=99
export N_PREDICT=128
export GGML_SYCL_ENABLE_VMM=0
export MEASURE_TTFT=1
export RUN_BENCH=1
export BENCH_REPS=1
export ALLOW_MULTI_GPU=0
export NUMACTL_ENABLE=1
export NUMACTL_ARGS='--physcpubind=1-51,105-155 --membind=0'
export LLAMA_NUMA=numactl
export EXTRA_ARGS='-fa on -ncmoe 16'
