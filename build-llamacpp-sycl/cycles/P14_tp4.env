# P14_tp4: pack GPU0 then GPU1 (both tiles each) — never one tile per GPU
#   GPU0: tiles 0,1 | GPU1: tiles 2,3
export ALLOW_MULTI_GPU=1
export PACK_TILES_PER_GPU=2
export TP=4
export ZE_FLAT_DEVICE_HIERARCHY=FLAT
export ZE_AFFINITY_MASK=0,1,2,3
export SPLIT_MODE=tensor
export TENSOR_SPLIT=0.25,0.25,0.25,0.25
export NGL=99
export N_PREDICT=128
export GGML_SYCL_ENABLE_VMM=0
export MEASURE_TTFT=1
export RUN_BENCH=1
export BENCH_REPS=1
export EXTRA_ARGS='-fa on'
