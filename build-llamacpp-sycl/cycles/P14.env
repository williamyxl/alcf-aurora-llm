# P14 family — TP-style scaling with DENSE tile packing.
#
# Hard placement rule (Aurora Max 1550 = 2 tiles / GPU in FLAT):
#   - Always take BOTH tiles of a GPU before opening another GPU.
#   - Affinity must be a contiguous prefix of FLAT tile ids: 0..N-1
#   - NEVER sparse masks like 0,2,4,6 (one tile per GPU).
#
# Same-GPU maximum is TP=2 (tiles 0,1 on GPU0). TP=4/8 need more GPUs but
# still pack: GPU0+GPU1 fully, then GPU2+GPU3, etc.
#
#   TP=2 → GPU0          tiles 0,1
#   TP=4 → GPU0+GPU1     tiles 0,1,2,3
#   TP=8 → GPU0..GPU3    tiles 0..7
#
# Submit:
#   qsub -v CYCLE=P14_tp2 -o .../perf_P14_tp2.out bench_llamacpp_sycl_perf.pbs
#   qsub -v CYCLE=P14_tp4 ...
#   qsub -v CYCLE=P14_tp8 ...

export ALLOW_MULTI_GPU=1
export PACK_TILES_PER_GPU=2
export ZE_FLAT_DEVICE_HIERARCHY=FLAT
export SPLIT_MODE=tensor
export NGL=99
export N_PREDICT=128
export GGML_SYCL_ENABLE_VMM=0
export MEASURE_TTFT=1
export RUN_BENCH=1
export BENCH_REPS=1
export EXTRA_ARGS='-fa on'

# Stub defaults = densest same-GPU case; use P14_tp* for real runs.
export ZE_AFFINITY_MASK=${ZE_AFFINITY_MASK:-0,1}
export TP=${TP:-2}
export TENSOR_SPLIT=${TENSOR_SPLIT:-0.5,0.5}
