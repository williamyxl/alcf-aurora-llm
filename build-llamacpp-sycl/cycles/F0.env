# F0: Phase F — 1 GPU tile + all MoE experts on CPU
# NOTE: intentional *no* NUMA bind — unbound host baseline. Use F4 for local-DDR NUMA.
# Use -ncmoe 99 (not -cmoe): llama-bench only accepts --n-cpu-moe; N>>n_layer ≈ all experts.
# See PLAN.md Phase F
export ZE_FLAT_DEVICE_HIERARCHY=FLAT
export ZE_AFFINITY_MASK=0
export SPLIT_MODE=none
export NGL=99
export N_PREDICT=128
export GGML_SYCL_ENABLE_VMM=0
export MEASURE_TTFT=1
export RUN_BENCH=1
export BENCH_REPS=1
export ALLOW_MULTI_GPU=0
export NUMACTL_ENABLE=0
export EXTRA_ARGS='-fa on -ncmoe 99'
