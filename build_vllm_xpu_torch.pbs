#!/bin/bash -l
# Phase 2: build torch XPU (PVC). Expect multiple chained debug jobs (KEEP_BUILD_DIR=1).
# NO frameworks module. Requires Phase 1 CLOSED (triton wheel in $WHEELS).
#
# Submit:  qsub build_vllm_xpu_torch.pbs
#
#PBS -l select=1
#PBS -l place=scatter
#PBS -l walltime=00:59:59
#PBS -q debug
#PBS -A MatSciAI
#PBS -l filesystems=flare
#PBS -N vllm-xpu-p2
#PBS -o /lus/flare/projects/MOFA/xiaoliyan/workdir/llm/gpt-oss-120b/build-vllm-xpu/logs/phase2_torch.out
#PBS -j oe

export WORKDIR=/lus/flare/projects/MOFA/xiaoliyan/workdir/llm/gpt-oss-120b
export BUILD=$WORKDIR/build-vllm-xpu
export ENV=$BUILD/env
export WHEELS=$BUILD/$(whoami)
export LOGS=$BUILD/logs
export RECIPES=$BUILD/frameworks-standalone
export http_proxy=http://proxy.alcf.anl.gov:3128
export https_proxy=http://proxy.alcf.anl.gov:3128
export ftp_proxy=http://proxy.alcf.anl.gov:3128
export FRAMEWORKS_ROOT_DIR=$BUILD
export FRAMEWORKS_PYTHON_VERSION=3.12
export TMPDIR=/tmp
export RAY_TMPDIR=/tmp
export ZE_FLAT_DEVICE_HIERARCHY=FLAT
export KEEP_BUILD_DIR=1

mkdir -p "$WHEELS" "$LOGS"

source /lus/flare/projects/MOFA/xiaoliyan/software/miniforge3/etc/profile.d/conda.sh
set -a
source "$BUILD/pins.env"
set +a
conda activate "$ENV"

module load oneapi/release/2025.3.1

echo "host=$(hostname)"
echo "date=$(date)"
echo "PHASE_STATUS:"
cat "$BUILD/PHASE_STATUS.md"
grep -q 'phase=1 status=PASS' "$BUILD/PHASE_STATUS.md" || { echo "Phase 1 not CLOSED"; exit 1; }
ls -lh "$WHEELS"/triton-*.whl
module list
which uv cmake ninja python icpx

cd "$RECIPES"
echo "=== nightly_wheels/torch ==="
./nightly_wheels/torch
echo "torch_exit=$?"

echo "=== artifacts ==="
ls -lh "$WHEELS"/torch-*.whl 2>/dev/null || echo "NO torch wheel yet"

if ls "$WHEELS"/torch-*.whl 1>/dev/null 2>&1; then
  echo "=== pip install torch into ENV ==="
  python -m pip install "$WHEELS"/torch-*.whl
  echo "=== xpu check under mpiexec ==="
  mpiexec -n 1 --ppn 1 python -c "import torch; print('torch', torch.__version__); print('xpu_available', torch.xpu.is_available()); print('xpu_count', torch.xpu.device_count())"
fi

echo "date=$(date)"
