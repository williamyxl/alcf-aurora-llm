#!/bin/bash -l
# Phase 6: LoRA/SFT one-epoch smoke on gpt-oss-120b (Torch-XPU + IPEX; no vLLM).
# Submit:  qsub train_lora_smoke.pbs
#
#PBS -l select=1
#PBS -l place=scatter
#PBS -l walltime=00:59:59
#PBS -q debug
#PBS -A MatSciAI
#PBS -l filesystems=flare
#PBS -N gpt-oss-lora
#PBS -o /lus/flare/projects/MOFA/xiaoliyan/workdir/llm/gpt-oss-120b/build-vllm-xpu/logs/train_lora.out
#PBS -j oe

# Recipe docs: README.md and build-vllm-xpu/SUCCESS_TRAIN.md
export WORKDIR=/lus/flare/projects/MOFA/xiaoliyan/workdir/llm/gpt-oss-120b
export BUILD=$WORKDIR/build-vllm-xpu
export ENV=$BUILD/env
export LOGS=$BUILD/logs
mkdir -p "$LOGS" "$WORKDIR/checkpoints/lora-smoke"
cd "$WORKDIR"

source /lus/flare/projects/MOFA/xiaoliyan/software/miniforge3/etc/profile.d/conda.sh
set -a
source "$BUILD/pins.env"
set +a
conda activate "$ENV"
module load oneapi/release/2025.3.1

export HF_HOME=$WORKDIR/.cache/huggingface
export TMPDIR=/tmp
export ZE_FLAT_DEVICE_HIERARCHY=FLAT
export ONEAPI_DEVICE_SELECTOR=level_zero:gpu
export TORCHDYNAMO_DISABLE=1
export TORCH_COMPILE_DISABLE=1
unset SYCL_CACHE_PERSISTENT
export SYCL_CACHE_DIR=$TMPDIR/sycl_cache_${PBS_JOBID:-$$}
mkdir -p "$SYCL_CACHE_DIR"

echo "host=$(hostname)"
echo "date=$(date)"
echo "python=$(command -v python)"
module list | grep -i frameworks && { echo "frameworks loaded — FAIL"; exit 1; } || echo "no frameworks OK"

python - <<'PY'
import peft, trl, datasets, accelerate, intel_extension_for_pytorch as ipex, torch
print("torch", torch.__version__)
print("peft", peft.__version__)
print("trl", trl.__version__)
print("datasets", datasets.__version__)
print("accelerate", accelerate.__version__)
print("ipex", ipex.__version__)
print("SUCCESS_INFER_exists", __import__("pathlib").Path("build-vllm-xpu/SUCCESS_INFER.md").is_file())
PY

mpiexec -n 1 --ppn 1 python -c "import torch; print('xpu_count', torch.xpu.device_count())"
mpiexec -n 1 --ppn 1 python lora_one_epoch.py
echo "date=$(date)"
