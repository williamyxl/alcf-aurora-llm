# G0: Phase G FINAL — max context (131072) · 2-tile pure GPU + optional local NUMA for host threads
export ALLOW_MULTI_GPU=1
export PACK_TILES_PER_GPU=2
export TP=2
export ZE_FLAT_DEVICE_HIERARCHY=FLAT
export ZE_AFFINITY_MASK=0,1
export SPLIT_MODE=tensor
export TENSOR_SPLIT=0.5,0.5
export NGL=99
export N_CTX=131072
export N_PREDICT=256
export N_PP=8192
export GGML_SYCL_ENABLE_VMM=0
export MEASURE_TTFT=1
export RUN_BENCH=1
export BENCH_REPS=1
export BENCH_DEADLINE_S=2000
export FILL_CTX=1
# debug/debug-scaling max 59m — cannot full-fill 128k; keep N_CTX=131072 for KV, cap prompt
export FILL_CTX_TOKENS=8192
# Keep host threads/staging on socket 0 next to GPU0
export NUMACTL_ENABLE=1
export NUMACTL_ARGS='--physcpubind=1-51,105-155 --membind=0'
export LLAMA_NUMA=numactl
export EXTRA_ARGS='-fa on'
