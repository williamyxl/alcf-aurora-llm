# F4h: Phase F — ncmoe99 + sock0 CPU-HBM preferred (ALCF: NUMA node 2)
# Docs: https://docs.alcf.anl.gov/aurora/running-jobs-aurora/#using-the-hbm-on-the-sapphire-rapids-cpus
export ZE_FLAT_DEVICE_HIERARCHY=FLAT
export ZE_AFFINITY_MASK=0
export SPLIT_MODE=none
export NGL=99
export N_PREDICT=128
export GGML_SYCL_ENABLE_VMM=0
export MEASURE_TTFT=1
export RUN_BENCH=1
export BENCH_REPS=1
export ALLOW_MULTI_GPU=0
export NUMACTL_ENABLE=1
export NUMACTL_ARGS='--physcpubind=1-51,105-155 --preferred=2'
export LLAMA_NUMA=numactl
export N_THREADS=32
export EXTRA_ARGS='-fa on -ncmoe 99'
