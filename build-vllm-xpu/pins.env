# Self-built Torch-XPU + IPEX + vLLM stack on Aurora — NO frameworks module.
# Use project miniforge only (do not module load miniforge3).
# Load oneapi after recipe module reset (see ci-lib.sh patch).
#
# Co-build pins: torch major.minor MUST match IPEX (xpu-main => Torch 2.10).
# Status: Phases 0–6 PASS (2026-07-18). See VERSIONS.md / README.md.
#
# Runtime Triton is frameworks 3.6 (225cdbde), NOT the self-built 3.8 wheel.
# All FRAMEWORKS_* must be exported (recipes run as child scripts with set -u).

export FRAMEWORKS_PYTHON_VERSION=3.12

# Must be non-empty or IPEX / oneCCL recipe stages are skipped upstream.
export FRAMEWORKS_TORCH_VERSION=v2.10.0
export FRAMEWORKS_TRITON_VERSION=225cdbde
export FRAMEWORKS_IPEX_VERSION=xpu-main
export FRAMEWORKS_TORCHCCL_VERSION=master
export FRAMEWORKS_VLLM_VERSION=main
export FRAMEWORKS_VLLM_XPU_KERNELS_VERSION=main

# Artifact / wheel dir: $FRAMEWORKS_ROOT_DIR/$USER
# Build order: deps/llvm -> triton -> torch (USE_XPU=1, PVC) -> ipex/oneccl
#            -> vllm_xpu_kernels/vllm (VLLM_TARGET_DEVICE=xpu)
# Runtime: same $ENV for inference (vLLM) and finetune (peft/trl on Torch+IPEX).
#
# Locked runtime identities (from VERSIONS.md):
#   torch 2.10.0a0+git449b176
#   triton 3.6.0+git225cdbde (+ driver.c OpenCL-optional patch)
#   ipex 2.10.10+gitd0f992f
#   oneccl_bind_pt 2.8.0+xpu
#   vllm 0.1.dev1+g109b736b8
#   vllm_xpu_kernels 0.1.dev1+g4002cea90
