# Phase S4 â€” MoEâ†’CPU short ctx; force MoE onto Xeon Max HBM (not DDR5)
# Inkling: MoE may use TP<8; pure GPU requires TP>=8
# Aurora Flat: NUMA 2 = sock0 HBM (~64G). GPU0 â†’ sock0 â†’ --membind=2
# Reuses MO1 tile count; if S3 winner is MO2, retarget ZE_AFFINITY / TP before submit.
export ALLOW_MULTI_GPU=0
export ZE_FLAT_DEVICE_HIERARCHY=FLAT
export ZE_AFFINITY_MASK=0
export SPLIT_MODE=none
export NGL=99
export N_CTX=4096
export N_PREDICT=128
export N_PP=512
export N_THREADS=32
export GGML_SYCL_ENABLE_VMM=0
export MEASURE_TTFT=1
export RUN_BENCH=0
export NUMACTL_ENABLE=1
export NUMACTL_ARGS='--physcpubind=1-51,105-155 --membind=2'
export LLAMA_NUMA=numactl
export EXTRA_ARGS='-fa on -ncmoe 99 --reasoning off'
