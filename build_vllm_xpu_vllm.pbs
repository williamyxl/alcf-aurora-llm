#!/bin/bash -l
# Phase 4: build vllm_xpu_kernels then vllm; install into $ENV.
# Requires Phase 3 CLOSED (IPEX + oneCCL). Capacity, 1 node, 10h.
#
# Submit:  qsub build_vllm_xpu_vllm.pbs
#
#PBS -l select=1
#PBS -l place=scatter
#PBS -l walltime=00:59:59
#PBS -q debug
#PBS -A MatSciAI
#PBS -l filesystems=flare
#PBS -N vllm-xpu-p4
#PBS -o /lus/flare/projects/MOFA/xiaoliyan/workdir/llm/gpt-oss-120b/build-vllm-xpu/logs/phase4_vllm.out
#PBS -j oe

export WORKDIR=/lus/flare/projects/MOFA/xiaoliyan/workdir/llm/gpt-oss-120b
export BUILD=$WORKDIR/build-vllm-xpu
export ENV=$BUILD/env
export WHEELS=$BUILD/$(whoami)
export LOGS=$BUILD/logs
export RECIPES=$BUILD/frameworks-standalone
export http_proxy=http://proxy.alcf.anl.gov:3128
export https_proxy=http://proxy.alcf.anl.gov:3128
export ftp_proxy=http://proxy.alcf.anl.gov:3128
export FRAMEWORKS_ROOT_DIR=$BUILD
export FRAMEWORKS_PYTHON_VERSION=3.12
export TMPDIR=/tmp
export RAY_TMPDIR=/tmp
export ZE_FLAT_DEVICE_HIERARCHY=FLAT
export KEEP_BUILD_DIR=1

mkdir -p "$WHEELS" "$LOGS"

source /lus/flare/projects/MOFA/xiaoliyan/software/miniforge3/etc/profile.d/conda.sh
set -a
source "$BUILD/pins.env"
set +a
conda activate "$ENV"

module load oneapi/release/2025.3.1

echo "host=$(hostname)"
echo "date=$(date)"
grep -q 'phase=3 status=PASS' "$BUILD/PHASE_STATUS.md" || { echo "Phase 3 not CLOSED"; exit 1; }
ls -lh "$WHEELS"/torch-*.whl "$WHEELS"/triton-*.whl
module list

cd "$RECIPES"
echo "=== nightly_wheels/vllm_xpu_kernels ==="
./nightly_wheels/vllm_xpu_kernels
echo "kernels_exit=$?"
ls -lh "$WHEELS"/vllm_xpu_kernels-*.whl 2>/dev/null || echo "NO kernels wheel yet"

echo "=== nightly_wheels/vllm ==="
./nightly_wheels/vllm
echo "vllm_exit=$?"
ls -lh "$WHEELS"/vllm-*.whl 2>/dev/null || echo "NO vllm wheel yet"

# NEVER plain pip install local vllm wheel — deps resolve to CUDA torch on PyPI.
if ls "$WHEELS"/vllm_xpu_kernels-*.whl 1>/dev/null 2>&1; then
  python -m pip install --force-reinstall --no-deps "$WHEELS"/vllm_xpu_kernels-*.whl
fi
if ls "$WHEELS"/vllm-*.whl 1>/dev/null 2>&1; then
  python -m pip install --force-reinstall --no-deps "$WHEELS"/vllm-*.whl
  python -c "import torch; print('torch', torch.__version__); assert 'git' in torch.__version__ or torch.__version__.startswith('2.10')"
  python -c "import vllm; print('vllm', vllm.__version__)"
  python -c "import vllm.model_executor.models.gpt_oss as m; print(m.__file__)"
fi

echo "date=$(date)"
